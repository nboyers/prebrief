{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"rootDir": "src",
		"noEmit": true,
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"types": ["vite/client"]
	},
	"include": [
		"src/renderer/**/*.ts",
		"src/renderer/**/*.tsx",
		"src/shared/**/*.ts"
	]
}
